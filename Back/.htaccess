# Evitar que la página se cargue en un iframe (clickjacking)
Header always set X-Frame-Options "DENY"

# Evitar que el navegador adivine el tipo de contenido
Header always set X-Content-Type-Options "nosniff"

# Controlar qué información se envía al navegar a otra web
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Política de seguridad de contenido básica
Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"